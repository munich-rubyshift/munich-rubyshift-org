<% module_namespacing do -%>
class <%= class_name %>ComponentPreview < ViewComponent::Preview
  # <%= class_name %>
  # ---
  # What does it do?
  # You should add a [type] to the params below!
  #
<% attributes.each do |attribute| -%>
  # @param <%= attribute.name %>
<% end -%>
  def default<%= "(#{render_signature})" if render_signature %>
    render(<%= class_name %>Component.new<%= "(#{render_signature.gsub('"', '')})" if render_signature %>)
  end
end
<% end -%>
