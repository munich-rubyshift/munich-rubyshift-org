<% content_for :title, "Organizations" %>

<h1>Organizations</h1>

<% if Rails.env.development? %>
  <p>
    <%= link_to "✏️", avo.resources_entities_organizations_path, "up-follow": false %>
  </p>
<% end %>

<ul id="entities_organizations">
  <% @entities_organizations.each do |entities_organization| %>
    <li>
      <%= render entities_organization %>
      <p>
        <%= link_to "Show this organization", entities_organization %>
      </p>
    </li>
  <% end %>
</ul>
